# UNI IA Workshop LP — Environment Variables
# Copy this file to .env and fill in values for local dev.
# In production (Vercel), set these in dashboard → Settings → Environment Variables.

# Site canonical URL (used for og:url, schema.org, sitemap)
# Default for preview: https://uni-ia-workshop.vercel.app
# Production: https://workshop.uniia.com.br (or whatever final domain)
PUBLIC_SITE_URL=https://uni-ia-workshop.vercel.app

# REQUIRED — Checkout URL. Must start with wa.me/ or https://wa.me/
# Build will fail if invalid format.
# Format: wa.me/{numero}?text=mensagem-pre-preenchida
PUBLIC_CHECKOUT_URL=https://wa.me/5531999999999?text=Quero%20vaga%20Workshop%20UNI%20IA%20%C2%B7%20R%2447%20%28Lote%201%29

# WhatsApp number for footer display + "Fala comigo" link
PUBLIC_WHATSAPP_NUMBER=+5531999999999

# Active lote: 1, 2, or 3
# Controls which lote card is highlighted on Dobra 09 + Schema.org price
PUBLIC_LOTE_ATIVO=1

# Optional — Google Tag Manager
# Leave empty to skip GTM injection
PUBLIC_GTM_ID=

# Optional — Meta (Facebook) Pixel
# Leave empty to skip Pixel injection
PUBLIC_META_PIXEL_ID=
