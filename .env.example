# UNI IA Workshop LP — Environment Variables
# Copy to .env (local) ou setar no Vercel dashboard (prod).

PUBLIC_SITE_URL=https://uni-ia-workshop.vercel.app

# Checkout URL — aceita wa.me/, checkout.ticto.app/, pay.hotmart.com/,
# sun.eduzz.com/, pagar.me/, checkout.stripe.com/, buy.stripe.com/
# Build falha se host fora dessa whitelist.
PUBLIC_CHECKOUT_URL=https://checkout.ticto.app/SEU_LINK_AQUI

# WhatsApp number for footer + "Fala comigo" pós-FAQ
PUBLIC_WHATSAPP_NUMBER=+5531999999999

# Active lote: 1, 2, or 3 (controla destaque visual + Schema.org price)
PUBLIC_LOTE_ATIVO=1

# Optional analytics
PUBLIC_GTM_ID=
PUBLIC_META_PIXEL_ID=
