---
import Logo from './Logo.astro';
import { getEntry } from 'astro:content';

const data = await getEntry('workshop', 'main');
const w = data!.data;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '+5531999999999';
const cleanWa = whatsappNumber.replace(/\D/g, '');
---
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <Logo variant="dark" height={28} />
      <div class="footer__tagline">
        Pare de estudar IA. <em class="serif-mint">Execute.</em>
      </div>
    </div>
    <div class="footer__grid">
      <div>
        <p class="footer__label">Endereço</p>
        <p class="footer__value">{w.workshop.address}</p>
      </div>
      <div>
        <p class="footer__label">WhatsApp</p>
        <p class="footer__value">
          <a href={`https://wa.me/${cleanWa}`} rel="noopener noreferrer">{whatsappNumber}</a>
        </p>
      </div>
      <div>
        <p class="footer__label">E-mail</p>
        <p class="footer__value">
          <a href="mailto:contato@uniia.com.br">contato@uniia.com.br</a>
        </p>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2026 UNI IA · Todos os direitos reservados</span>
      <nav class="footer__nav">
        <a href="/politica-de-privacidade">Política de Privacidade</a>
        <a href="/termos-de-uso">Termos de Uso</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-black);
    color: var(--color-white);
    padding: 4rem 1.5rem 2.5rem;
  }
  @media (min-width: 768px) {
    .footer { padding: 5rem 3rem 3rem; }
  }
  .footer__top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 2.5rem;
  }
  @media (min-width: 768px) {
    .footer__top { flex-direction: row; align-items: center; justify-content: space-between; }
  }
  .footer__tagline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.03em;
  }
  .footer__tagline em {
    color: var(--color-mint);
  }
  .footer__grid {
    display: grid;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 768px) {
    .footer__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .footer__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gray-4);
    margin-bottom: 0.5rem;
  }
  .footer__value {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
  }
  .footer__value a:hover { color: var(--color-mint); }
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 0.85rem;
    color: var(--color-gray-4);
  }
  @media (min-width: 768px) {
    .footer__bottom { flex-direction: row; justify-content: space-between; align-items: center; }
  }
  .footer__nav {
    display: flex;
    gap: 1.5rem;
  }
  .footer__nav a:hover { color: var(--color-mint); }
</style>
