---
import Logo from './Logo.astro';
import { getEntry } from 'astro:content';

const data = await getEntry('workshop', 'main');
const w = data!.data.workshop;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '+5531999999999';
const cleanWa = whatsappNumber.replace(/\D/g, '');
const wpHref = `https://wa.me/${cleanWa}`;
---
<footer class="footer">
  <div class="container footer__container">
    <div class="footer__grid">
      <div class="footer__brand">
        <Logo variant="dark" height={22} />
        <p class="footer__desc">
          Workshop UNI IA · Calendário Fechado em 3 Horas.<br/>
          {w.address}, {w.addressLocality}/{w.addressRegion}.
        </p>
      </div>

      <div class="footer__col">
        <span class="footer__col-title">// workshop</span>
        <a href="#hero">Sobre o Workshop</a>
        <a href="#preco">Preço · Lotes</a>
        <a href="#garantia">Garantia</a>
        <a href="#faq">Perguntas frequentes</a>
      </div>

      <div class="footer__col">
        <span class="footer__col-title">// contato</span>
        <a href={wpHref} rel="noopener noreferrer">WhatsApp · {whatsappNumber}</a>
        <a href="mailto:contato@uniia.com.br">contato@uniia.com.br</a>
        <a href={`https://maps.google.com/?q=${encodeURIComponent(w.address + ', ' + w.addressLocality)}`} rel="noopener noreferrer" target="_blank">Como chegar →</a>
      </div>

      <div class="footer__col">
        <span class="footer__col-title">// uni ia</span>
        <a href="#provas">Quem ensina</a>
        <a href="#autoridade">Autoridade</a>
        <a href="#logistica">Logística</a>
      </div>
    </div>

    <div class="footer__bottom">
      <span class="uni-mono footer__copyright">© 2026 UNI IA · Todos os direitos reservados</span>
      <span class="uni-mono footer__tagline">QUEM PILOTA NÃO ESPERA.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--uni-black);
    color: var(--uni-white);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 64px 24px 32px;
  }
  @media (min-width: 768px) {
    .footer { padding: 80px 32px 32px; }
  }
  .footer__container { max-width: var(--container-max); }
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 56px;
  }
  @media (min-width: 768px) {
    .footer__grid { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 32px; }
  }
  .footer__brand p { margin-top: 16px; }
  .footer__desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--uni-gray-4);
    max-width: 360px;
  }
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer__col-title {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--uni-mint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .footer__col a {
    font-size: 13px;
    color: var(--uni-gray-3);
    transition: color var(--dur-fast) var(--ease);
  }
  .footer__col a:hover { color: var(--uni-mint); }
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .footer__copyright,
  .footer__tagline {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.72);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .footer__tagline { color: rgba(255, 255, 255, 0.85); }
</style>
