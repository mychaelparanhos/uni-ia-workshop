---
import Logo from './Logo.astro';
import { getEntry } from 'astro:content';

const checkoutUrl = import.meta.env.PUBLIC_CHECKOUT_URL || 'https://wa.me/5531999999999';
const data = await getEntry('workshop', 'main');
const w = data!.data.workshop;
// Mono caption no header — data do workshop
const dateLabel = w.dateBR.split(' · ')[0]?.toUpperCase() || 'TERÇA · 19H';
---
<header id="site-header" class="header" data-revealed="false">
  <div class="header__inner">
    <Logo variant="dark" height={20} />
    <span class="uni-mono header__date">// próxima turma · {dateLabel}</span>
    <a
      href={checkoutUrl}
      class="uni-btn uni-btn-mint uni-btn-sm header__cta"
      data-track="cta_header_click"
      aria-label="Garantir vaga · R$ 67"
      rel="noopener noreferrer"
    >
      Garantir vaga · R$ 67 →
    </a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--uni-white);
    transform: translateY(-100%);
    transition: transform 0.25s var(--ease);
    will-change: transform;
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .header { background: rgba(10, 10, 10, 0.92); }
  }
  .header[data-revealed="true"] {
    transform: translateY(0);
  }
  .header__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .header__inner { padding: 16px 32px; gap: 24px; }
  }
  .header__date {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: none;
  }
  @media (min-width: 768px) {
    .header__date { display: inline-flex; }
  }
  .header__cta { margin-left: auto; }
</style>
