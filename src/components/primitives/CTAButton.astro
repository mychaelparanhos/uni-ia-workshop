---
interface Props {
  href: string;
  size?: 'md' | 'lg' | 'xl';
  variant?: 'primary' | 'secondary' | 'ghost';
  track: string;
  class?: string;
  ariaLabel?: string;
  disabled?: boolean;
}
const {
  href,
  size = 'md',
  variant = 'primary',
  track,
  class: className,
  ariaLabel,
  disabled = false,
} = Astro.props;

const variantClass = {
  primary: 'uni-btn-mint',
  secondary: 'uni-btn-ghost-light',
  ghost: 'uni-btn-ghost',
}[variant];

const sizeClass = `uni-btn-${size}`;
---
<a
  href={disabled ? undefined : href}
  class={`uni-btn ${variantClass} ${sizeClass} ${disabled ? 'uni-btn-disabled' : ''} ${className || ''}`}
  data-track={track}
  aria-label={ariaLabel}
  aria-disabled={disabled ? 'true' : undefined}
  rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
>
  <slot />
</a>
