---
interface Props {
  size?: number;
  class?: string;
}
const { size = 18, class: className } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="3"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  style="display:inline-block;vertical-align:middle;color:var(--color-mint)"
>
  <polyline points="20 6 9 17 4 12" />
</svg>
