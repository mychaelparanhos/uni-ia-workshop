---
/*
  ┌─────────────────────────────────────────────────────────┐
  │ Section.astro — Sistema 60-30-10 (Design System v1.5)   │
  │                                                         │
  │   matrix    = fundo preto, texto branco (tensão)        │
  │               grid lines + mint glow auto via matrix-bg │
  │   editorial = fundo branco, texto preto (leitura)       │
  │   cta-mint  = fundo mint, texto preto (oferta)          │
  │                                                         │
  │ Hooks de CSS em modes.css resolvem o tema via           │
  │ [data-mode="..."]. Componentes filhos consomem          │
  │ currentColor.                                           │
  └─────────────────────────────────────────────────────────┘
*/
interface Props {
  id: string;
  mode: 'matrix' | 'editorial' | 'cta-mint';
  band?: 'mint-soft';
  class?: string;
}
const { id, mode, band, class: className } = Astro.props;

// matrix mode adiciona grid lines automaticamente (do design system)
const autoMatrixBg = mode === 'matrix' && !className?.includes('matrix-bg');
const sectionClass = [autoMatrixBg ? 'matrix-bg' : '', className].filter(Boolean).join(' ');
---
<section id={id} data-mode={mode} data-band={band} class={sectionClass}>
  <div class="container">
    <slot />
  </div>
</section>
