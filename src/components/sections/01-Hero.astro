---
import { Image } from 'astro:assets';
import Section from '../primitives/Section.astro';
import Heading from '../primitives/Heading.astro';
import Accent from '../primitives/Accent.astro';
import CTAButton from '../primitives/CTAButton.astro';
import { getEntry } from 'astro:content';
import heroImg from '../../assets/images/hero-notebook-maos.png';

const data = await getEntry('workshop', 'main');
const w = data!.data.hero;
const lote = data!.data.preco.lotes[0]; // Lote 1 ativo
const checkoutUrl = import.meta.env.PUBLIC_CHECKOUT_URL;
---
<Section id="hero" mode="matrix" class="hero matrix-bg">
  <div class="mint-glow mint-glow--primary" aria-hidden="true"></div>
  <div class="mint-glow mint-glow--secondary" aria-hidden="true"></div>

  <div class="hero__grid">
    <div class="hero__copy">
      <span class="uni-eyebrow hero__eyebrow fade-up">▼ workshop uni ia · lote 1 ativo</span>

      <Heading level={1} class="hero__title fade-up">
        {w.headline} <Accent>{w.accent}</Accent>{w.headlineAfter}
      </Heading>

      <p class="hero__sub fade-up">{w.subheadline}</p>

      <ul class="hero__bullets unstyled fade-up">
        {w.bullets.map((b) => (
          <li>
            <span class="uni-triangle" aria-hidden="true"></span>
            <span>{b}</span>
          </li>
        ))}
      </ul>

      <div class="hero__cta fade-up">
        <CTAButton
          href={checkoutUrl}
          size="lg"
          variant="primary"
          track="cta_hero_click"
          ariaLabel={w.ctaLabel}
        >
          {w.ctaLabel} →
        </CTAButton>
        <a href="#preco" class="uni-btn uni-btn-ghost uni-btn-lg">Ver programa</a>
        <span class="uni-mono hero__spots">● {lote.vagas} vagas · lote 1 decolagem</span>
      </div>
    </div>

    <div class="hero__image fade-up" aria-hidden="true">
      <Image
        src={heroImg}
        alt="Notebook aberto com mãos digitando — produzindo conteúdo profissional com IA"
        widths={[400, 800, 1200]}
        sizes="(min-width: 1024px) 480px, (min-width: 768px) 380px, 100vw"
        quality={82}
        loading="eager"
        fetchpriority="high"
        class="hero__image-el"
      />
    </div>
  </div>
</Section>
<div id="hero-sentinel" aria-hidden="true" style="height:1px"></div>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 96px !important;
  }
  @media (min-width: 768px) {
    .hero { padding-block: 120px 100px !important; }
  }

  .mint-glow {
    position: absolute;
    pointer-events: none;
    background: radial-gradient(circle, rgba(0, 229, 160, 0.4), transparent 60%);
    filter: blur(60px);
    z-index: 0;
  }
  .mint-glow--primary {
    width: 600px;
    height: 600px;
    bottom: -200px;
    right: -100px;
  }
  .mint-glow--secondary {
    width: 300px;
    height: 300px;
    top: -50px;
    left: -100px;
    opacity: 0.5;
  }

  .hero .container {
    position: relative;
    z-index: 2;
    max-width: 1100px;
  }

  .hero__eyebrow {
    color: var(--uni-mint);
  }
  .hero__eyebrow::before { display: none; } /* triângulo ▼ já está no texto */

  .hero__title {
    margin: 24px 0 28px;
  }

  .hero__sub {
    font-size: 17px;
    line-height: 1.5;
    max-width: 620px;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 32px;
  }
  @media (min-width: 768px) {
    .hero__sub { font-size: 19px; }
  }

  .hero__bullets {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 28px;
    margin-bottom: 40px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 15px;
    font-weight: 500;
  }
  .hero__bullets li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero__bullets .uni-triangle {
    color: var(--uni-mint);
    font-size: 12px;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .hero__spots {
    font-size: 11px;
    color: var(--uni-gray-4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-left: 8px;
  }

  .hero__grid {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero__grid {
      grid-template-columns: 1fr 480px;
      gap: 64px;
    }
  }

  .hero__image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .hero__image::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.35));
    pointer-events: none;
  }
  .hero__image-el {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  @media (max-width: 1023px) {
    .hero__image { max-width: 560px; margin-inline: auto; }
  }
</style>
