---
import Section from '../primitives/Section.astro';
import Heading from '../primitives/Heading.astro';
import Accent from '../primitives/Accent.astro';
import { getEntry } from 'astro:content';

const data = await getEntry('workshop', 'main');
const w = data!.data.problema;
---
<Section id="problema" mode="matrix">
  <p class="eyebrow fade-up">{w.eyebrow}</p>
  <Heading level={2} class="fade-up">
    {w.headlinePre} <Accent>{w.accent}</Accent>.
  </Heading>
  <p class="problema__sub fade-up">{w.subheadline}</p>
  <div class="problema__grid">
    <ul class="unstyled problema__col">
      <p class="problema__label fade-up">Autocríticas</p>
      {w.autocriticas.map((q) => <li class="problema__quote fade-up">{q}</li>)}
    </ul>
    <ul class="unstyled problema__col">
      <p class="problema__label fade-up">Medos</p>
      {w.medos.map((q) => <li class="problema__quote fade-up">{q}</li>)}
    </ul>
  </div>
</Section>

<style>
  .problema__sub {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.7);
    margin: 1rem 0 2.5rem;
    max-width: 720px;
  }
  .problema__grid {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .problema__grid { grid-template-columns: 1fr 1fr; gap: 3rem; }
  }
  .problema__col { display: flex; flex-direction: column; gap: 0.75rem; }
  .problema__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mint);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .problema__quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.4;
    color: rgba(255,255,255,0.92);
    padding-left: 1rem;
    border-left: 3px solid var(--color-mint);
  }
</style>
