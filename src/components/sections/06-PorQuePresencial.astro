---
import { Image } from 'astro:assets';
import Section from '../primitives/Section.astro';
import Heading from '../primitives/Heading.astro';
import Accent from '../primitives/Accent.astro';
import CTAButton from '../primitives/CTAButton.astro';
import { getEntry } from 'astro:content';
import comparativoImg from '../../assets/images/comparativo-sala-vs-sozinho.png';

const data = await getEntry('workshop', 'main');
const w = data!.data.porQuePresencial;
const checkoutUrl = import.meta.env.PUBLIC_CHECKOUT_URL;
---
<Section id="por-que-presencial" mode="editorial">
  <p class="uni-eyebrow fade-up">{w.eyebrow}</p>
  <Heading level={2} class="fade-up">
    {w.headlinePre}{' '}<Accent>{w.accent}</Accent>{' '}{w.headlinePost}
  </Heading>

  <figure class="porque__hero fade-up">
    <Image
      src={comparativoImg}
      alt="Comparativo visual: pessoa estudando sozinha em casa à noite versus sala presencial cheia com projeção"
      widths={[600, 1000, 1400, 1800]}
      sizes="(min-width: 1024px) 1000px, 100vw"
      quality={84}
      loading="lazy"
      class="porque__hero-el"
    />
  </figure>

  <div class="porque__checklist fade-up">
    <p class="porque__checklist-titulo">{w.checklistTitulo}</p>
    <ul class="porque__checklist-list unstyled">
      {w.checklist.map((item) => (
        <li class="porque__checklist-item">
          <span class="porque__check" aria-hidden="true">✓</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <blockquote class="porque__reframe fade-up">
    <p class="porque__reframe-principal">{w.reframe.principal}</p>
    <p class="porque__reframe-complemento">{w.reframe.complemento}</p>
  </blockquote>

  <p class="porque__fechamento fade-up">{w.fechamento}</p>

  <div class="porque__cta fade-up">
    <CTAButton
      href={checkoutUrl}
      size="lg"
      variant="primary"
      track="cta_porque_click"
      ariaLabel={w.ctaLabel}
    >
      {w.ctaLabel}
    </CTAButton>
  </div>
</Section>

<style>
  .porque__hero {
    margin: 2.5rem 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-gray-1);
    max-width: 1000px;
  }
  .porque__hero-el {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .porque__checklist {
    max-width: 720px;
    margin: 2.5rem 0;
    padding: 1.75rem 2rem;
    background: var(--color-gray-1);
    border-radius: var(--radius-lg);
    border-left: 3px solid var(--color-mint);
  }
  .porque__checklist-titulo {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mint-dark);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .porque__checklist-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .porque__checklist-item {
    display: flex;
    gap: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-gray-5);
  }
  .porque__check {
    color: var(--color-mint-dark);
    font-weight: 700;
    flex-shrink: 0;
    line-height: 1.55;
  }

  .porque__reframe {
    margin: 3rem 0;
    padding: 2rem 0 2rem 2rem;
    border-left: 4px solid var(--color-mint);
    max-width: 880px;
  }
  .porque__reframe-principal {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-black);
    margin-bottom: 1.25rem;
    white-space: pre-line;
  }
  @media (min-width: 768px) {
    .porque__reframe-principal { font-size: 2.5rem; }
  }
  @media (min-width: 1024px) {
    .porque__reframe-principal { font-size: 3rem; }
  }
  .porque__reframe-complemento {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--color-gray-5);
    max-width: 720px;
  }

  .porque__fechamento {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-black);
    max-width: 800px;
    margin: 2rem 0;
  }

  .porque__cta {
    margin-top: 2rem;
  }
</style>
