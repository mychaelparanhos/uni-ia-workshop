---
import Section from '../primitives/Section.astro';
import Heading from '../primitives/Heading.astro';
import CheckIcon from '../primitives/CheckIcon.astro';
import { getEntry } from 'astro:content';
import { em } from '../../lib/markdown-emphasis';

const data = await getEntry('workshop', 'main');
const w = data!.data.recap;
---
<Section id="recapitulacao" mode="editorial">
  <p class="eyebrow fade-up">{w.eyebrow}</p>
  <Heading level={2} class="fade-up">{w.headline}</Heading>
  <ul class="unstyled recap__list">
    {w.itens.map((item) => (
      <li class="fade-up"><CheckIcon size={18} /> <span>{item}</span></li>
    ))}
  </ul>
  <div class="recap__ancoragem fade-up">
    <p class="recap__total">{w.ancoragem}</p>
    <p class="recap__exp" set:html={em(w.ancoragemPos)} />
  </div>
</Section>

<style>
  .recap__list {
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 800px;
  }
  .recap__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    color: var(--color-black);
    line-height: 1.5;
  }
  .recap__list li > :global(svg) { flex-shrink: 0; margin-top: 0.2rem; }
  .recap__ancoragem {
    margin-top: 2rem;
    padding: 2rem;
    background: var(--color-mint-bg);
    border: 1px solid var(--color-mint);
    border-radius: var(--radius-lg);
    max-width: 800px;
  }
  .recap__total {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-black);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .recap__exp {
    font-size: 1rem;
    color: var(--color-gray-5);
    line-height: 1.6;
  }
</style>
